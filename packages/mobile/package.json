    "@react-navigation/native-stack": "^6.9.26",
    "@shopify/react-native-skia": "1.2.3",
    "@starfleet/shared": "file:./shared",
    "react": "18.2.0",
    "react-native": "0.74.2",
    "react-native-gesture-handler": "2.16.1",
    "react-native-reanimated": "3.11.0",
    "react-native-safe-area-context": "4.10.1",
