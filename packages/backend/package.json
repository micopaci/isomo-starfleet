{
  "name": "@starfleet/backend",
  "version": "5.0.0",
  "private": true,
  "main": "server.js",
  "scripts": {
    "start": "node migrate.js && node server.js",
    "migrate": "node migrate.js",
    "test:telemetry": "node --test test/starlinkTelemetry.test.js",
    "test:starlink-usage": "node --test test/starlinkPortalUsage.test.js",
    "dev": "node --watch server.js",
    "agent:token": "node scripts/generate_agent_token.js",
    "intune:check": "node scripts/check_intune_data.js",
    "devices:duplicates": "node scripts/check_device_duplicates.js",
    "devices:dedupe": "node scripts/dedupe_devices_by_serial.js",
    "weather:check": "node scripts/check_weather_data.js",
    "starlink:portal:usage": "node scripts/starlink_portal_usage_worker.js",
    "starlink:token": "node scripts/generate_starlink_collector_token.js",
    "starlink:portal:cloud-sync": "node scripts/starlink_portal_cloud_sync_worker.js",
    "test:starlink-portal": "node --test test/starlinkPortalCloudSync.test.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.68.0",
    "@google-cloud/cloud-sql-connector": "^1.11.0",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.14",
    "pg": "^8.12.0",
    "playwright": "^1.61.0",
    "satellite.js": "^5.0.0",
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
