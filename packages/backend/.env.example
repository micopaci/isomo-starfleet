# Database (Neon PostgreSQL or any Postgres)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth
JWT_SECRET=change-this-to-a-long-random-string
# Optional RS256 keys. Leave blank to use JWT_SECRET/HS256.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
AGENT_TOKEN_TTL=365d

# Server
PORT=3000
NODE_ENV=production
ALLOWED_ORIGINS=https://starfleet.icircles.rw
DEVICE_ONLINE_HOURS=72
DEVICE_STALE_HOURS=336

# Microsoft Graph / Intune (optional)
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_INTUNE_SYNC_ENABLED=true
GRAPH_INTUNE_SYNC_INTERVAL_MIN=30

# Intune on-demand remediation policy GUIDs (optional)
# If you use one shared Starfleet remediation package, set REMEDIATION_POLICY_ID.
REMEDIATION_POLICY_ID=
REMEDIATION_POLICY_DIAGNOSTICS=
REMEDIATION_POLICY_LOCATION_REFRESH=
REMEDIATION_POLICY_DATA_PULL=
REMEDIATION_POLICY_PING_DISH=
REMEDIATION_POLICY_REBOOT_STARLINK=
# Security remediations (no REMEDIATION_POLICY_ID fallback — action 503s until set).
# GUIDs of the "Starfleet - Update Chrome" / "Starfleet - Windows Update" packages;
# see packages/agent/INTUNE_SETUP.md.
REMEDIATION_POLICY_CHROME_UPDATE=
REMEDIATION_POLICY_WINDOWS_UPDATE=

# Microsoft Defender for Endpoint TVM sync (optional)
# Reuses the GRAPH_* app registration; needs WindowsDefenderATP application
# permissions Machine.Read.All + Vulnerability.Read.All with admin consent.
DEFENDER_TVM_SYNC_ENABLED=true
DEFENDER_TVM_SYNC_INTERVAL_MIN=360
# Geo override if the global host 403s (e.g. https://api-eu.securitycenter.microsoft.com)
DEFENDER_API_BASE_URL=
# Batched email + critical push when a sync discovers new vulnerabilities.
SECURITY_NOTIFY_ENABLED=true
# Minimum severity that creates an alert_events row (critical|high|medium|low|all).
# The Security page always shows ALL vulnerabilities; this only gates the Alerts
# feed — the full TVM feed carries thousands of medium/low CVEs.
SECURITY_ALERT_MIN_SEVERITY=high

# AI mitigation guidance (OpenAI / Codex — skipped when OPENAI_API_KEY is unset)
OPENAI_API_KEY=
AI_MITIGATION_ENABLED=true
AI_MITIGATION_MODEL=gpt-4o
# Optional: override the OpenAI base URL (Azure OpenAI, a gateway, or a proxy).
OPENAI_BASE_URL=

# Weather correlation (Open-Meteo, free — no key needed)
OPEN_METEO_ENABLED=true

# Weekly email digest
DIGEST_ENABLED=true
DIGEST_TO=ops@yourorg.rw
DIGEST_FROM=starfleet@yourorg.rw
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Starlink portal usage collector (Windows Server 2019 + WSL2)
STARFLEET_API_URL=https://api.starfleet.icircles.rw
STARFLEET_COLLECTOR_TOKEN=
STARLINK_PORTAL_EMAIL=support@icircles.rw
STARLINK_PORTAL_PROFILE_DIR=/srv/starfleet/starlink-browser-profile
STARLINK_PORTAL_HEADLESS=true
STARLINK_PORTAL_USAGE_MODE=snapshot
STARLINK_PORTAL_DAILY_DATE_BACKDAYS=1
STARLINK_GMAIL_DWD_KEY_FILE=/etc/starfleet/starlink-gmail-dwd.json
STARLINK_GMAIL_OTP_QUERY=newer_than:15m (from:starlink.com OR from:noreply@starlink.com OR Starlink) (code OR verification OR login)
STARLINK_USAGE_REPORT_ENABLED=true
STARLINK_USAGE_REPORT_TO=ops@yourorg.rw
STARLINK_USAGE_REPORT_FROM=starfleet@yourorg.rw

# Frontend URL (used in digest emails)
DASHBOARD_URL=https://starfleet.icircles.rw

# Extra CORS origins are comma-separated in ALLOWED_ORIGINS.
