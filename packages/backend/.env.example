# Database (Neon PostgreSQL or any Postgres)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth
JWT_SECRET=change-this-to-a-long-random-string

# Server
PORT=3000
NODE_ENV=production

# Microsoft Graph / Intune (optional)
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_INTUNE_SYNC_ENABLED=true
GRAPH_INTUNE_SYNC_INTERVAL_MIN=30

# Intune on-demand remediation policy GUIDs (optional)
# If you use one shared Starfleet remediation package, set REMEDIATION_POLICY_ID.
REMEDIATION_POLICY_ID=
REMEDIATION_POLICY_DIAGNOSTICS=
REMEDIATION_POLICY_LOCATION_REFRESH=
REMEDIATION_POLICY_DATA_PULL=
REMEDIATION_POLICY_PING_DISH=
REMEDIATION_POLICY_REBOOT_STARLINK=

# Weather correlation (Open-Meteo, free — no key needed)
OPEN_METEO_ENABLED=true

# Weekly email digest
DIGEST_ENABLED=true
DIGEST_TO=ops@yourorg.rw
DIGEST_FROM=starfleet@yourorg.rw
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Frontend URL (used in digest emails)
DASHBOARD_URL=https://starfleet.icircles.rw

# Extra CORS origins (comma-separated, optional)
ALLOWED_ORIGINS=https://starfleet.icircles.rw
