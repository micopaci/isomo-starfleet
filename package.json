{
  "name": "starlink-fleet-monitor",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/backend",
    "packages/desktop",
    "packages/shared",
    "packages/web"
  ],
  "scripts": {
    "dev":     "concurrently -k -n BACKEND,DESKTOP -c cyan,magenta \"npm run start --workspace=packages/backend\" \"npm run dev --workspace=packages/desktop\"",
    "backend": "npm run start --workspace=packages/backend",
    "backend:dev": "npm run dev --workspace=packages/backend",
    "desktop": "npm run dev --workspace=packages/desktop",
    "migrate": "npm run migrate --workspace=packages/backend"
  }
}
